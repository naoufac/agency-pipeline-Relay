[Unit]
Description=Telegram alert that %i failed (external OnFailure signal — never trusts the failing unit)

[Service]
Type=oneshot
EnvironmentFile=/root/.relay-monitor.env
ExecStart=/usr/bin/curl -s -m 20 https://api.telegram.org/bot${TG_TOKEN}/sendMessage -d chat_id=${TG_CHAT_ID} -d text=🧨 systemd: %i FAILED on the Relay box — check journalctl -u %i
