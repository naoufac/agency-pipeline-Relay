{
  "name": "agency-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous agency pipeline: brief -> planner -> dependency DAG of AI calls, stage-by-stage, zero-trust verification, Supabase/Postgres board.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run -s build && npm run -s spec:check && npm run -s cms:check && npm run -s layout:check && npm run -s ecom:check && npm run -s app:check && npm run -s scope:check && npm run -s content:check && npm run -s leak:check && npm run -s migrate:check && npm run -s theme:check && npm run -s jsonld:check && npm run -s design:check && npm run -s figma:check && npm run -s pwa:check && npm run -s chain:check && npm run -s apk:check && npm run -s i18n:check && npm run -s backup:check && npm run -s llm:check && npm run -s chat:check && npm run -s lifecycle:check && npm run -s billing:check",
    "app:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/app-check.ts",
    "scope:check": "tsx src/scope-check.ts",
    "serve": "set -a; . ./.env 2>/dev/null; set +a; tsx src/server.ts",
    "worker": "set -a; . ./.env 2>/dev/null; set +a; tsx src/worker.ts",
    "kpi": "set -a; . ./.env 2>/dev/null; set +a; tsx src/kpi-cli.ts",
    "theme:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/theme-check.ts",
    "apk": "set -a; . ./.env 2>/dev/null; set +a; tsx src/apk.ts",
    "chat:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/chat-test.ts",
    "llm:check": "tsx src/llm-test.ts",
    "backup:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/backup-test.ts",
    "i18n:check": "tsx src/i18n-test.ts",
    "apk:check": "tsx src/apk-test.ts",
    "spec:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/spec-test.ts",
    "cms:check": "tsx src/cms/check.ts",
    "migrate:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/migrate-check.ts",
    "auth:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/auth-check.ts",
    "alert:check": "set -a; . ./.env 2>/dev/null; . /root/.relay-monitor.env 2>/dev/null; set +a; tsx src/alert-check.ts",
    "leak:check": "tsx src/leak-check.ts",
    "layout:check": "tsx src/layout-check.ts",
    "ecom:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/ecom-check.ts",
    "content:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/content-check.ts",
    "prove:directus": "set -a; . ./.env 2>/dev/null; set +a; tsx src/cms/prove-directus.ts",
    "cms:status": "set -a; . ./.env 2>/dev/null; set +a; tsx src/cms/status.ts",
    "cms:build": "set -a; . ./.env 2>/dev/null; set +a; tsx src/cms/finalize-cli.ts",
    "stress": "set -a; . ./.env 2>/dev/null; set +a; tsx _stress.ts",
    "eval": "set -a; . ./.env 2>/dev/null; set +a; tsx src/eval.ts",
    "dogfood": "set -a; . ./.env 2>/dev/null; set +a; tsx src/dogfood-cli.ts",
    "pwa:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/pwa-check.ts",
    "chain:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/chain-check.ts",
    "digest": "set -a; . ./.env 2>/dev/null; set +a; tsx src/digest.ts",
    "canary": "set -a; . ./.env 2>/dev/null; set +a; tsx src/canary.ts",
    "billing:check": "set -a; . ./.env 2>/dev/null; set +a; tsx src/billing-check.ts",
    "lifecycle:check": "node --experimental-strip-types src/lifecycle-check.ts",
    "design:check": "node --experimental-strip-types src/design-check.ts",
    "figma:check": "node --experimental-strip-types src/figma-check.ts",
    "jsonld:check": "node --experimental-strip-types src/jsonld-check.ts"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.13.1",
    "playwright": "^1.61.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}